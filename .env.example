# Roosk NexGen Platform — Environment Configuration
# Copy to .env and fill in production values

# --- Database ---
POSTGRES_DB=nexgen_platform
POSTGRES_USER=nexgen
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
DATABASE_URL=postgresql+asyncpg://nexgen:CHANGE_ME_IN_PRODUCTION@db:5432/nexgen_platform

# --- Application ---
DEBUG=false
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
CORS_ORIGINS=["https://roosk.ai"]

# --- AWS / AI ---
BEDROCK_ONLY=true
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Monitoring ---
PROMETHEUS_ENABLED=true
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME

# --- Frontend ---
API_URL=http://backend:8000
NEXT_PUBLIC_SITE_URL=https://roosk.ai

# --- SSL ---
SSL_EMAIL=admin@roosk.ai
SSL_DOMAIN=roosk.ai
